{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@agent-paymaster/shared": ["packages/shared/src/index.ts"],
      "@agent-paymaster/shared/*": ["packages/shared/src/*"],
      "@agent-paymaster/api/*": ["packages/api/src/*"],
      "@agent-paymaster/bundler/*": ["packages/bundler/src/*"],
      "@agent-paymaster/sdk": ["packages/sdk/src/index.ts"],
      "@agent-paymaster/sdk/*": ["packages/sdk/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
