{
  "name": "agent-paymaster",
  "private": true,
  "version": "0.2.6",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "check": "pnpm lint && pnpm format && pnpm test && pnpm test:contracts",
    "build": "pnpm -r --filter '!@agent-paymaster/paymaster-contracts' build",
    "dev": "pnpm --parallel --filter @agent-paymaster/shared --filter @agent-paymaster/api --filter @agent-paymaster/bundler dev",
    "lint": "pnpm -r --if-present --filter '!@agent-paymaster/paymaster-contracts' lint",
    "release:notes": "node scripts/extract-changelog-section.mjs",
    "release:validate-version": "node scripts/validate-release-version.mjs",
    "smoke:deploy": "node scripts/deployment-smoke.mjs",
    "test": "pnpm build && pnpm -r --filter '!@agent-paymaster/paymaster-contracts' test",
    "test:contracts": "pnpm --filter @agent-paymaster/paymaster-contracts test",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@next/eslint-plugin-next": "15.5.12",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.15.0",
    "prettier": "^3.5.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.7"
  }
}
